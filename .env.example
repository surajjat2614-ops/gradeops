# Environment Variables for GradeOps Vision
# Copy this file to .env and replace the values for production deployment.

# ---------------------------------------------------------
# DATABASE CONFIGURATION
# ---------------------------------------------------------
# By default, GradeOps Vision falls back to a local SQLite database (gradeops.db).
# For production, provide a PostgreSQL connection string:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/gradeops

# ---------------------------------------------------------
# CLOUD STORAGE CONFIGURATION (AWS S3)
# ---------------------------------------------------------
# By default, uploads and snippets are stored locally in the `/data` directory.
# To enable S3 cloud storage for production, provide the following:
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET=gradeops-vision-bucket

# ---------------------------------------------------------
# MACHINE LEARNING & MODELS
# ---------------------------------------------------------
# Optional: HuggingFace Token for faster model downloads and avoiding rate limits.
# HF_TOKEN=hf_your_huggingface_token_here

# ---------------------------------------------------------
# SECURITY
# ---------------------------------------------------------
# Secret key for JWT Authentication encoding. Change this in production!
SECRET_KEY=gradeops_super_secret_key_change_in_prod
ALGORITHM=HS256